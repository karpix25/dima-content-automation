KIE_IMAGE_ASPECT_RATIO=9:16
KIE_IMAGE_RESOLUTION=1K
KIE_POLL_TIMEOUT_SECONDS=300
KIE_POLL_INTERVAL_SECONDS=3
MONTAGE_RENDERER=auto
HYPERFRAMES_PROJECT_DIR=/app/hyperframes-auto
REMOTION_PROJECT_DIR=
